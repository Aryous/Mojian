#!/bin/bash
# 主控监督 — 提交前自动执行溯源验证
# 仅在 src/ 或 tests/ 有变更时触发（文档提交不阻断）

SCRIPTS_DIR="$(git rev-parse --show-toplevel)/.claude/scripts"
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

frontmatter_value() {
  local file="$1"
  local key="$2"

  awk -v key="$key" '
    NR == 1 && $0 == "---" { in_fm = 1; next }
    in_fm && $0 == "---" { exit }
    in_fm && $0 ~ ("^" key ":") {
      sub("^[^:]+:[[:space:]]*", "", $0)
      print $0
      exit
    }
  ' "$file"
}

find_trace_exemption() {
  local today file status scope expires
  today="$(date +%F)"

  for file in "$PROJECT_ROOT"/docs/exemptions/*.md; do
    [[ -f "$file" ]] || continue
    status="$(frontmatter_value "$file" "status")"
    scope="$(frontmatter_value "$file" "scope")"
    expires="$(frontmatter_value "$file" "expires")"

    if [[ "$status" == "approved" && "$scope" == "trace" && -n "$expires" && ( "$expires" > "$today" || "$expires" == "$today" ) ]]; then
      echo "$file"
      return 0
    fi
  done

  return 1
}

staged_docs=()
while IFS= read -r path; do
  case "$path" in
    .claude/ARCHITECTURE.md|docs/design-docs/tech-decisions.md|docs/exec-plans/active/*.md|docs/exec-plans/completed/*.md|docs/exemptions/*.md)
      [[ "$path" == "docs/exemptions/template.md" ]] && continue
      staged_docs+=("$PROJECT_ROOT/$path")
      ;;
  esac
done < <(git diff --cached --name-only)

if (( ${#staged_docs[@]} > 0 )); then
  echo "📄 Running doc-lint on staged control docs..."
  if ! bash "$SCRIPTS_DIR/doc-lint.sh" "${staged_docs[@]}"; then
    echo ""
    echo "❌ Commit blocked: control docs failed doc-lint."
    exit 1
  fi
fi

# 检查暂存区是否包含 src/ 或 tests/ 文件
if git diff --cached --name-only | grep -qE '^(src|tests)/'; then
  if [[ -f "$SCRIPTS_DIR/trace.sh" ]]; then
    if exemption="$(find_trace_exemption)"; then
      echo "⚠️  Using approved trace exemption: ${exemption#$PROJECT_ROOT/}"
      bash "$SCRIPTS_DIR/trace.sh" || true
    else
      echo "🔍 Running traceability check (src/ files staged)..."
      if ! bash "$SCRIPTS_DIR/trace.sh" --strict; then
        echo ""
        echo "❌ Commit blocked: requirements not fully traced to code."
        echo "   Add @req annotations or implement missing features."
        echo "   Or add an approved trace exemption under docs/exemptions/."
        echo "   Run: bash .claude/scripts/trace.sh (without --strict) to see details."
        exit 1
      fi
    fi
  fi
else
  echo "📄 Docs-only commit, skipping traceability check."
fi
